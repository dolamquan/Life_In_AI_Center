# PostgreSQL connection string
# Local:      postgresql://user:password@localhost:5432/ai_tutor
# Render:     Filled automatically via the render.yaml database binding
DATABASE_URL="postgresql://user:password@localhost:5432/ai_tutor"

# ChromaDB – run locally with: chroma run --path ./chroma_data
# Production: replace with your hosted ChromaDB URL (Railway / Fly.io / ChromaDB Cloud)
CHROMA_URL="http://localhost:8000"

# OpenAI API key
OPENAI_API_KEY="sk-..."

# Port (Render sets this automatically)
PORT=3000

# Allowed CORS origin – set to your Vercel frontend URL in production
# Leave blank to allow all origins (fine for development)
CORS_ORIGIN=https://your-frontend.vercel.app
